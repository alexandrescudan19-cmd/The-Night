--- !u!114 &1837753702
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1837753700}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9541d86e2fd84c1d9990edf0852d74ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\U0001F530 TUTORIAL \u2013 The Night \U0001F530\nBine ai venit, comandant!
    E timpul s\u0103 aperi fort\u0103rea\u021Ba \u0219i s\u0103 conduci trupele \xEEn
    lupta pentru supravie\u021Buire.\n\n\U0001F3AE OBIECTIVUL JOCULUI\n\xCEn The
    Night, fort\u0103rea\u021Ba ta este ultimul bastion al umanit\u0103\u021Bii.
    Valuri de zombii se revars\u0103 \xEEn fiecare noapte, iar tu e\u0219ti singura
    speran\u021B\u0103.\nFolose\u0219te strategia, comand\u0103-\u021Bi solda\u021Bii
    \u0219i ap\u0103r\u0103 zidurile p\xE2n\u0103 la ultimul om.\n\n\U0001F579\uFE0F
    CONTROALE JUC\u0102TOR\nWASD \u2013 Deplaseaz\u0103 personajul principal\n\nSPACE
    \u2013 Atac\u0103 (corpul t\u0103u e \u0219i arm\u0103!)\n\nESCAPE \u2013 Pauzeaz\u0103
    jocul \u0219i acceseaz\u0103 meniul\n\n\U0001FA96 COMENZI SOLDATI \u2013 Grupa
    1 (Spawner 1)\nZ \u2013 Trimite solda\u021Bii \xEEn urm\u0103rire \u0219i atac\n\nX
    \u2013 Atac\u0103 pozi\u021Bia inamic\u0103\n\nR \u2013 Retragere rapid\u0103\n\n1
    / 2 / 3 \u2013 Schimb\u0103 forma\u021Bia (linie / coloan\u0103 / cerc)\n\n\U0001FA96
    COMENZI SOLDATI \u2013 Grupa 2 (Spawner 2)\nC \u2013 Trimite solda\u021Bii \xEEn
    urm\u0103rire \u0219i atac\n\nV \u2013 Atac\u0103 pozi\u021Bia inamic\u0103\n\nR
    \u2013 Retragere rapid\u0103 (comun\u0103)\n\n4 / 5 / 6 \u2013 Schimb\u0103 forma\u021Bia
    (linie / coloan\u0103 / cerc)\n\n\U0001F9E0 STRATEGIE SUGERAT\u0102\n\u2714\uFE0F
    Folose\u0219te forma\u021Biile pentru a bloca c\u0103ile de acces ale zombilor\n\u2714\uFE0F
    Combin\u0103 unit\u0103\u021Bi \xEEn forma\u021Bii diferite pentru a optimiza
    ap\u0103rarea\n\u2714\uFE0F Retrage-\u021Bi trupele strategic cu R c\xE2nd sunt
    dep\u0103\u0219ite\n\u2714\uFE0F Nu uita s\u0103-\u021Bi protejezi baza \u2013
    dac\u0103 cade, jocul e pierdut\n\n\U0001F3AF VICTORIA\n\u2705 \xCEnvinge toate
    valurile de zombii\n\u2705 Asigur\u0103-te c\u0103 fort\u0103rea\u021Ba rezist\u0103\n\u2705
    Supravie\u021Buie\u0219te noaptea \u2013 \u0219i transform\u0103 haosul \xEEn
    ordine\n\n\U0001F480 \xCENFR\xC2NGERE\n\u274C Dac\u0103 baza e distrus\u0103\u2026
    e\u0219ti terminat\n\u274C Dac\u0103 zombii trec de linia ta de ap\u0103rare
    \u2013 riposteaz\u0103 rapid sau retrage-te\n\n\U0001F3C1 SFATURI FINALE\n\U0001F56F\uFE0F
    Fiecare noapte e diferit\u0103. Ajusteaz\u0103 strategia.\n\U0001FA96 Solda\u021Bii
    t\u0103i sunt cheia. Fii liderul lor.\n\U0001F9DF\u200D\u2642\uFE0F Zombii nu
    se opresc. Nici tu s\u0103 nu te opre\u0219ti."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 0b65c99348f068b49bef5db0bb76a6e4, type: 2}
